# =========================================================================
# Multi-Provider Super Agent Platform Configuration Environment
# =========================================================================
# Copy this file to '.env' in the same directory and input your active API keys.
#

# 1. Google Gemini API Configuration (Default Model: gemini-2.5-flash)
# Get a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. OpenAI API Configuration (Fallback Model: gpt-4o-mini)
# Get a key from OpenAI Developer Platform: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
